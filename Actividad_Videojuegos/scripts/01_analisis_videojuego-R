## Género y Región

ventas_region_genero <- videojuegos_limpio %>%
  group_by(Genre) %>%
  summarise(
    Norteamerica = sum(NA_Sales, na.rm = TRUE),
    Europa = sum(EU_Sales, na.rm = TRUE),
    Japon = sum(JP_Sales, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  pivot_longer(
    cols = c(Norteamerica, Europa, Japon),
    names_to = "region",
    values_to = "ventas"
  )

ventas_region_genero

Grafica9 <- ggplot(
  ventas_region_genero,
  aes(
    x = reorder(Genre, ventas),
    y = ventas,
    fill = region
  )
) +
  geom_col(show.legend = FALSE) +
  coord_flip() +
  facet_wrap(~region) +
  scale_fill_manual(
    values = c(
      "Norteamerica" = "#007979",
      "Europa" = "#9BCF53",
      "Japon" = "#FF6868"
    )
  ) +
  labs(
    title = "Ventas por género en distintas regiones",
    subtitle = "Comparación entre Norteamérica, Europa y Japón",
    x = "Género",
    y = "Ventas acumuladas (millones de copias)"
  ) +
  theme_videojuegos()

Grafica9

ggsave(
  filename = "figures/Grafica9.png",
  plot = Grafica9,
  width = 8,
  height = 5,
  dpi = 300
)


